# ════════════════════════════════════════════════════════════════
# Production Environment — Офисные кресла Алматы
# ════════════════════════════════════════════════════════════════
# ВАЖНО: Этот файл — ШАБЛОН. Реальные значения хранить в секрете.
# Скопировать в .env и заполнить перед деплоем.

APP_NAME="Офисные кресла Алматы"
APP_ENV=production
APP_KEY=                          # php artisan key:generate
APP_DEBUG=false                   # ОБЯЗАТЕЛЬНО false в production
APP_URL=https://your-domain.kz

APP_LOCALE=ru
APP_FALLBACK_LOCALE=ru
APP_FAKER_LOCALE=ru_RU
APP_TIMEZONE=Asia/Almaty

# ── Логирование ───────────────────────────────────────────────
LOG_CHANNEL=daily
LOG_LEVEL=error                   # В production только ошибки
LOG_DAILY_DAYS=14                 # Хранить логи 14 дней

# ── База данных ───────────────────────────────────────────────
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=chairs_db
DB_USERNAME=chairs_user
DB_PASSWORD=STRONG_RANDOM_PASSWORD_HERE
DB_CHARSET=utf8mb4
DB_COLLATION=utf8mb4_unicode_ci

# ── Кэш ──────────────────────────────────────────────────────
# Рекомендуется Redis если доступен, иначе file
CACHE_STORE=file
# CACHE_STORE=redis
# REDIS_HOST=127.0.0.1
# REDIS_PASSWORD=null
# REDIS_PORT=6379

# ── Очереди ───────────────────────────────────────────────────
QUEUE_CONNECTION=database         # или redis если доступен

# ── Сессии ────────────────────────────────────────────────────
SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_SECURE_COOKIE=true        # Только HTTPS
SESSION_SAME_SITE=lax

# ── Файлы ─────────────────────────────────────────────────────
FILESYSTEM_DISK=public

# ── Почта (для уведомлений) ───────────────────────────────────
MAIL_MAILER=smtp
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your@gmail.com
MAIL_PASSWORD=your_app_password
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=your@gmail.com
MAIL_FROM_NAME="${APP_NAME}"
